[user]
        signingkey = C2056057916F84A327F73A57EF6DE6CB33EA2869
        name = Veniamin Shapovalov
        email = veniaminshp@gmail.com
[commit]
        gpgSign = true
[gpg]
        program = /usr/bin/gpg
[pull]
        rebase = false
[gui]
        pruneduringfetch = true
[smartgit "submodule"]
        fetchalways = false
        update = true
        initializenew = true
[push]
        recurseSubmodules = check
        followTags = true
        default = current
[filter "lfs"]
        clean = git-lfs clean -- %f
        smudge = git-lfs smudge -- %f
        process = git-lfs filter-process
        required = true
[init]
        defaultBranch = main
[http]
        postBuffer = 1048576000
[alias]
        fm = fetch origin master
        tree = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
        cm = commit -m
        last = log -1 HEAD --stat
        st = status -sb
        blame = blame -w -M -C
[credential]
        helper = cache
[format]
        pretty = format:%C(yellow)%h%Creset -%C(red)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset
[help]
        autocorrect = 1
[color]
        ui = true
[color "branch"]
        current = yellow reverse
        local = yellow
        remote = green
[color "status"]
        added = yellow
        changed = green
        untracked = red
[core]
        ignorecase = false
        preloadindex = true
        fscache = true
[gc]
        auto = 256
[submodule]
        fetchJobs = 4
